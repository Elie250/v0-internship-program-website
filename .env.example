# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
# Optional overrides (defaults: noreply@energyandlogics.com / admin@energyandlogics.com)
EMAIL_FROM=Energy & Logics <noreply@energyandlogics.com>
ADMIN_NOTIFICATION_EMAIL=admin@energyandlogics.com
# Weekly leadership report recipients (comma-separated)
LEADERSHIP_REPORT_EMAILS=admin@energyandlogics.com

# Optional: Application Settings
NEXT_PUBLIC_APP_NAME=Energy & Logics
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 — media storage (products, courses, receipts, hero videos)
# Create Account API token with Object Read & Write on your bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=platform-media
# Custom domain connected in R2 → e.g. https://media.energyandlogics.com
R2_PUBLIC_BASE_URL=
# Same URL for client-side hero video URLs (required on Vercel)
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
# Optional override for hero playlist base (defaults to R2_PUBLIC_BASE_URL/hero)
# NEXT_PUBLIC_HERO_VIDEOS_BASE_URL=https://media.energyandlogics.com/hero
# After creating the bucket, set CORS — see scripts/43-r2-cors.json

# Set to true to expose extra auth diagnostics (login always shows debug on failure)
AUTH_DEBUG=true

# MTN MoMo Collections API (future — manual MoMo receipt flow remains active until MTN approves API)
# MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# MTN_MOMO_PROVISION_BASE_URL=https://sandbox.momodeveloper.mtn.com/v1_0
# MTN_MOMO_COLLECTION_BASE_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0
# MTN_MOMO_CALLBACK_HOST=energyandlogics.com
