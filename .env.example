# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
# Optional overrides (defaults: noreply@energyandlogics.com / admin@energyandlogics.com)
EMAIL_FROM=Energy & Logics <noreply@energyandlogics.com>
ADMIN_NOTIFICATION_EMAIL=admin@energyandlogics.com

# Optional: Application Settings
NEXT_PUBLIC_APP_NAME=Energy & Logics
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to true to expose extra auth diagnostics (login always shows debug on failure)
AUTH_DEBUG=true

# MTN MoMo Collections API (future — manual MoMo receipt flow remains active until MTN approves API)
# MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# MTN_MOMO_PROVISION_BASE_URL=https://sandbox.momodeveloper.mtn.com/v1_0
# MTN_MOMO_COLLECTION_BASE_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0
# MTN_MOMO_CALLBACK_HOST=energyandlogics.com

# IremboPay — online payments (MTN MoMo, Airtel, cards) — https://irembopay.com
# Dashboard → Settings → API Keys
IREMBOPAY_SECRET_KEY=
IREMBOPAY_PUBLIC_KEY=
IREMBOPAY_ENVIRONMENT=sandbox
# Payment account identifier and product code from IremboPay dashboard
IREMBOPAY_PAYMENT_ACCOUNT_IDENTIFIER=
IREMBOPAY_PRODUCT_CODE=
# Webhook URL to configure in IremboPay dashboard:
# https://www.energyandlogics.com/api/payments/irembopay/webhook
